Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # API запросы
    RewriteRule ^api/?$    backend/api/index.php      [QSA,L]
    RewriteRule ^api/(.+)$ backend/api/index.php/$1   [QSA,L]

    # Статика web/ — отдаём напрямую
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Корень / → web/index.html
    RewriteRule ^$  web/index.html [QSA,L]

    # Всё остальное → web/index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)$ web/index.html [QSA,L]
</IfModule>

<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>
