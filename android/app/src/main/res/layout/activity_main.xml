<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0E17">

    <!-- WebView -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Loading screen -->
    <LinearLayout
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#0F0E17">

        <TextView
            android:text="🪙"
            android:textSize="64sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:text="МамаКоин"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#F5C842"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="200dp"
            android:layout_height="6dp"
            android:progressTint="#F5C842"
            android:progressBackgroundTint="#2E2A47"
            android:max="100"/>
    </LinearLayout>

    <!-- Error screen -->
    <LinearLayout
        android:id="@+id/error_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#0F0E17"
        android:visibility="gone">

        <TextView
            android:text="⚠️"
            android:textSize="56sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/error_text"
            android:text="Нет подключения"
            android:textSize="18sp"
            android:textColor="#F0EEFF"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_retry"
            android:text="Повторить"
            android:textColor="#1A1000"
            android:backgroundTint="#F5C842"
            android:textStyle="bold"
            android:layout_width="160dp"
            android:layout_height="48dp"/>
    </LinearLayout>

</FrameLayout>
